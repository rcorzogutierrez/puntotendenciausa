---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title="Buscar artículos | La Tendencia USA"
			description="Busca entre todos los artículos de tecnología, inteligencia artificial y tendencias digitales de La Tendencia USA."
		/>
		<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
		<style>
			.search-hero {
				text-align: center;
				padding: 3.5em 1em 2.5em;
				margin-bottom: 2.5em;
			}
			.search-hero-icon {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 56px;
				height: 56px;
				background: var(--accent-glow);
				border: 1px solid rgba(99, 102, 241, 0.3);
				border-radius: 16px;
				margin-bottom: 1.2em;
				font-size: 1.5em;
			}
			.search-hero h1 {
				font-size: 2.4em;
				font-weight: 800;
				letter-spacing: -0.03em;
				color: var(--text-heading);
				margin-bottom: 0.4em;
			}
			.search-hero p {
				color: var(--text-muted);
				font-size: 0.95em;
				max-width: 420px;
				margin: 0 auto;
				line-height: 1.6;
			}

			.search-container {
				max-width: 760px;
				margin: 0 auto;
				padding: 0 1.5em 5em;
			}

			/* ── Pagefind UI overrides ─────────────────────────────── */
			#search {
				--pagefind-ui-scale: 1;
				--pagefind-ui-primary: var(--accent-light);
				--pagefind-ui-text: var(--text);
				--pagefind-ui-background: var(--bg-card);
				--pagefind-ui-border: var(--border);
				--pagefind-ui-tag: var(--bg-card);
				--pagefind-ui-border-width: 1px;
				--pagefind-ui-border-radius: 10px;
				--pagefind-ui-image-border-radius: 8px;
				--pagefind-ui-font: inherit;
			}

			/* Input */
			.pagefind-ui__form {
				position: relative;
			}
			.pagefind-ui__search-input {
				background: var(--bg-card) !important;
				color: var(--text-heading) !important;
				border: 1.5px solid var(--border) !important;
				border-radius: 12px !important;
				font-size: 1.05em !important;
				padding: 0.85em 1em 0.85em 3em !important;
				transition: border-color 0.2s, box-shadow 0.2s !important;
			}
			.pagefind-ui__search-input:focus {
				border-color: var(--accent) !important;
				outline: none !important;
				box-shadow: 0 0 0 3px var(--accent-glow) !important;
			}
			.pagefind-ui__search-input::placeholder {
				color: var(--text-muted) !important;
			}

			/* Botón limpiar */
			.pagefind-ui__search-clear {
				background: var(--bg-card) !important;
				color: var(--text-muted) !important;
				border: 1px solid var(--border) !important;
				border-radius: 8px !important;
				font-size: 0.8em !important;
				padding: 0.4em 0.9em !important;
				cursor: pointer;
				transition: color 0.15s, border-color 0.15s !important;
			}
			.pagefind-ui__search-clear:hover {
				color: var(--text-heading) !important;
				border-color: var(--border-hover) !important;
			}

			/* Mensaje de resultados */
			.pagefind-ui__message {
				color: var(--text-muted) !important;
				font-size: 0.85em !important;
				padding: 1.2em 0 0.8em !important;
				border-bottom: 1px solid var(--border) !important;
				margin-bottom: 0.5em !important;
			}

			/* Resultados */
			.pagefind-ui__results-area {
				margin-top: 0.5em;
			}
			.pagefind-ui__result {
				border: 1px solid var(--border) !important;
				border-radius: 12px !important;
				background: var(--bg-card) !important;
				padding: 1.4em 1.6em !important;
				margin-bottom: 1em !important;
				transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s !important;
				border-left: 3px solid var(--accent) !important;
			}
			.pagefind-ui__result:hover {
				border-color: var(--border-hover) !important;
				border-left-color: var(--accent-light) !important;
				box-shadow: var(--box-shadow-hover) !important;
				transform: translateY(-2px) !important;
			}
			.pagefind-ui__result-link {
				text-decoration: none !important;
			}
			.pagefind-ui__result-title {
				font-size: 1.1em !important;
				font-weight: 700 !important;
				color: var(--text-heading) !important;
				line-height: 1.35 !important;
				letter-spacing: -0.015em !important;
				transition: color 0.15s !important;
			}
			.pagefind-ui__result:hover .pagefind-ui__result-title {
				color: var(--accent-light) !important;
			}
			.pagefind-ui__result-excerpt {
				color: var(--text-muted) !important;
				font-size: 0.9em !important;
				line-height: 1.65 !important;
				margin-top: 0.5em !important;
			}
			/* Término resaltado */
			.pagefind-ui__result-excerpt mark {
				background: rgba(99, 102, 241, 0.25) !important;
				color: var(--accent-light) !important;
				border-radius: 3px !important;
				padding: 0 2px !important;
			}

			/* Imagen del resultado */
			.pagefind-ui__result-image-container {
				border-radius: 8px !important;
				overflow: hidden !important;
				flex-shrink: 0 !important;
			}

			/* Botón "cargar más" */
			.pagefind-ui__button {
				background: transparent !important;
				color: var(--accent-light) !important;
				border: 1.5px solid var(--accent) !important;
				border-radius: 999px !important;
				font-size: 0.9em !important;
				padding: 0.6em 1.8em !important;
				cursor: pointer !important;
				transition: background 0.2s, color 0.2s !important;
				margin-top: 0.5em !important;
			}
			.pagefind-ui__button:hover {
				background: var(--accent) !important;
				color: #fff !important;
			}

			/* Estado vacío / sin búsqueda */
			.search-empty-state {
				text-align: center;
				padding: 3em 1em;
				color: var(--text-muted);
				font-size: 0.95em;
				display: none;
			}
			.search-empty-state.visible {
				display: block;
			}

			@media (max-width: 600px) {
				.search-hero h1 { font-size: 1.8em; }
				.pagefind-ui__result { padding: 1em 1.1em !important; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="search-hero">
				<div class="search-hero-icon">🔍</div>
				<h1>Buscar artículos</h1>
				<p>Encuentra contenido sobre IA, tecnología, gadgets y tendencias digitales.</p>
			</div>

			<div class="search-container">
				<div id="search"></div>
			</div>
		</main>
		<Footer />

		<script is:inline>
			const s = document.createElement('script');
			s.src = '/pagefind/pagefind-ui.js';
			s.onload = () => {
				new PagefindUI({
					element: '#search',
					showSubResults: false,
					resetStyles: false,
					showImages: true,
					translations: {
						placeholder: 'Buscar artículos...',
						zero_results: 'Sin resultados para "[QUERY]" — intenta con otras palabras',
						many_results: '[COUNT] resultados para "[QUERY]"',
						one_result: '1 resultado para "[QUERY]"',
						alt_search: 'Buscando en su lugar "[DIFFERENT_QUERY]"...',
						search_suggestion: '¿Quisiste decir "[DIFFERENT_QUERY]"?',
						searching: 'Buscando...',
						load_more: 'Ver más resultados',
					},
				});

				// Fix: reemplazar [QUERY] con el término real si pagefind no lo hace
				const input = document.querySelector('.pagefind-ui__search-input');
				const observer = new MutationObserver(() => {
					const msg = document.querySelector('.pagefind-ui__message');
					if (msg && input && msg.textContent.includes('[QUERY]')) {
						msg.textContent = msg.textContent.replaceAll('[QUERY]', input.value);
					}
				});
				observer.observe(document.getElementById('search'), {
					childList: true,
					subtree: true,
				});
			};
			document.head.appendChild(s);
		</script>
	</body>
</html>
