---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { categoryToSlug, getPostCategory } from '../utils/categories';
import { unsplashCard, unsplashCardSrcset } from '../utils/images';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title="La Tendencia USA — Inteligencia Artificial y Tendencias Digitales en Español" description="Tecnología, inteligencia artificial y tendencias digitales explicadas en español para toda la comunidad latina e hispanohablante. Noticias tech sin tecnicismos." />
		<style>
			/* Override global main for full-width layout */
			main {
				width: 100%;
				max-width: 100%;
				padding: 0;
				margin: 0;
			}

			/* ── Hero ─────────────────────────────────────────── */
			.hero {
				position: relative;
				padding: 6em 1.5em 5em;
				text-align: center;
				overflow: hidden;
				border-bottom: 1px solid var(--border);
			}
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background:
					radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99, 102, 241, 0.22) 0%, transparent 70%),
					radial-gradient(ellipse 50% 40% at 80% 100%, rgba(34, 211, 238, 0.06) 0%, transparent 60%);
				pointer-events: none;
			}
			.hero-inner {
				position: relative;
				max-width: 720px;
				margin: 0 auto;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1.25em;
			}
			.hero-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-size: 0.72em;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--accent-light);
				background: var(--accent-glow);
				border: 1px solid rgba(99, 102, 241, 0.3);
				border-radius: 999px;
				padding: 0.4em 1em;
			}
			.hero h1 {
				font-size: clamp(2.5em, 6vw, 4em);
				font-weight: 900;
				letter-spacing: -0.04em;
				line-height: 1.1;
				color: var(--text-heading);
				margin: 0;
			}
			.hero h1 .accent {
				color: var(--accent-light);
			}
			.hero-tagline {
				font-size: clamp(1em, 2.5vw, 1.2em);
				color: var(--text-muted);
				max-width: 560px;
				line-height: 1.65;
				margin: 0;
			}
			.hero-actions {
				display: flex;
				align-items: center;
				gap: 1em;
				flex-wrap: wrap;
				justify-content: center;
				margin-top: 0.5em;
			}
			.btn-primary {
				display: inline-flex;
				align-items: center;
				padding: 0.75em 1.75em;
				background: var(--accent);
				color: #fff;
				font-weight: 700;
				font-size: 0.95em;
				border-radius: 999px;
				text-decoration: none;
				transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
				box-shadow: 0 0 24px rgba(99, 102, 241, 0.35);
			}
			.btn-primary:hover {
				background: var(--accent-btn-hover);
				transform: translateY(-2px);
				box-shadow: 0 0 36px rgba(79, 70, 229, 0.5);
				color: #fff;
			}
			.btn-secondary {
				display: inline-flex;
				align-items: center;
				padding: 0.75em 1.75em;
				background: transparent;
				color: var(--text-muted);
				font-weight: 600;
				font-size: 0.95em;
				border-radius: 999px;
				border: 1px solid var(--border);
				text-decoration: none;
				transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
			}
			.btn-secondary:hover {
				color: var(--text-heading);
				border-color: var(--border-hover);
				background: var(--bg-card);
			}

			/* ── Stats strip ────────────────────────────────────── */
			.stats-strip {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 2.5em;
				padding: 2em 1.5em;
				border-bottom: 1px solid var(--border);
				flex-wrap: wrap;
			}
			.stat {
				text-align: center;
			}
			.stat-value {
				display: block;
				font-size: 1.5em;
				font-weight: 800;
				color: var(--text-heading);
				letter-spacing: -0.03em;
			}
			.stat-label {
				font-size: 0.78em;
				color: var(--text-muted);
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}
			.stat-divider {
				width: 1px;
				height: 2.5em;
				background: var(--border);
			}

			/* ── Recent posts section ───────────────────────────── */
			.recent-section {
				max-width: 1100px;
				margin: 0 auto;
				padding: 4em 1.5em 5em;
			}
			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 2em;
				gap: 1em;
			}
			.section-header h2 {
				font-size: 1.5em;
				margin: 0;
			}
			.see-all {
				font-size: 0.88em;
				color: var(--accent-light);
				text-decoration: none;
				font-weight: 600;
				white-space: nowrap;
				transition: color 0.2s ease;
			}
			.see-all:hover {
				color: var(--cyan);
			}

			/* ── Cards grid ─────────────────────────────────────── */
			.cards-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5em;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.card {
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 14px;
				overflow: hidden;
				position: relative;
				transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
				display: flex;
				flex-direction: column;
			}
			.card:hover {
				border-color: var(--border-hover);
				box-shadow: var(--box-shadow-hover);
				transform: translateY(-3px);
			}
			.card-img {
				overflow: hidden;
				aspect-ratio: 16/9;
				flex-shrink: 0;
			}
			.card-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 0.4s ease;
				display: block;
			}
			.card:hover .card-img img {
				transform: scale(1.05);
			}
			.card-body {
				padding: 1.25em 1.4em 1.4em;
				display: flex;
				flex-direction: column;
				gap: 0.5em;
				flex: 1;
			}
			.card-category {
				position: relative;
				z-index: 2;
				display: inline-flex;
				font-size: 0.68em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent-light);
				text-decoration: none;
				width: fit-content;
				transition: color 0.2s ease;
			}
			.card-category:hover {
				color: var(--cyan);
			}
			.card-title {
				font-size: 1em;
				color: var(--text-heading);
				line-height: 1.4;
				margin: 0;
				font-weight: 600;
			}
			.card-title a {
				text-decoration: none;
				color: inherit;
			}
			.card-title a::after {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 1;
			}
			.card-desc {
				color: var(--text-muted);
				font-size: 0.85em;
				line-height: 1.55;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
				flex: 1;
			}
			.card-date {
				font-size: 0.78em;
				color: var(--text-muted);
				font-weight: 500;
				margin-top: auto;
				padding-top: 0.5em;
			}

			/* ── No posts state ─────────────────────────────────── */
			.no-posts {
				text-align: center;
				padding: 3em 1em;
				color: var(--text-muted);
			}

			/* ── SEO text section ───────────────────────────────── */
			.seo-section {
				max-width: 1100px;
				margin: 0 auto;
				padding: 3em 1.5em 4em;
				border-top: 1px solid var(--border);
			}
			.seo-section h2 {
				font-size: 1.4em;
				font-weight: 700;
				color: var(--text-heading);
				margin: 0 0 0.6em;
			}
			.seo-section h3 {
				font-size: 1.1em;
				font-weight: 700;
				color: var(--text-heading);
				margin: 1.5em 0 0.5em;
			}
			.seo-section p {
				color: var(--text-muted);
				font-size: 0.95em;
				line-height: 1.7;
				margin: 0;
				max-width: 760px;
			}

			/* ── Quote section ──────────────────────────────────── */
			.quote-section {
				padding: 3em 1.5em;
				text-align: center;
			}
			blockquote.featured-quote {
				max-width: 680px;
				margin: 0 auto;
				border-left: 4px solid var(--accent);
				padding: 1.2em 1.8em;
				background: var(--bg-card);
				border-radius: 0 8px 8px 0;
				text-align: left;
			}
			blockquote.featured-quote p {
				font-size: 1.15em;
				font-style: italic;
				color: var(--text);
				line-height: 1.7;
				margin: 0 0 0.8em;
			}
			blockquote.featured-quote cite {
				font-size: 0.9em;
				color: var(--text-muted);
				font-style: normal;
				font-weight: 600;
			}

			/* ── CTA bottom banner ──────────────────────────────── */
			.cta-banner {
				background: var(--bg-card);
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
				padding: 3.5em 1.5em;
				text-align: center;
			}
			.cta-banner h2 {
				font-size: 1.6em;
				margin-bottom: 0.5em;
			}
			.cta-banner p {
				color: var(--text-muted);
				font-size: 0.95em;
				max-width: 480px;
				margin: 0 auto 1.5em;
				line-height: 1.6;
			}

			/* ── Responsive ─────────────────────────────────────── */
			@media (max-width: 900px) {
				.cards-grid {
					grid-template-columns: repeat(2, 1fr);
				}
				.stat-divider {
					display: none;
				}
			}
			@media (max-width: 600px) {
				.hero {
					padding: 4em 1.25em 3.5em;
				}
				.cards-grid {
					grid-template-columns: 1fr;
				}
				.stats-strip {
					gap: 1.5em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<div class="hero-inner">
					<span class="hero-badge">IA · Tech · Tendencias</span>
					<h1>La Tendencia <span class="accent">USA</span></h1>
					<p class="hero-tagline">
						Tu referencia de tecnología, inteligencia artificial y tendencias digitales
						en español, para toda la comunidad latina e hispanohablante del mundo.
					</p>
					<div class="hero-actions">
						<a href="/blog" class="btn-primary">Explorar artículos →</a>
						<a href="/about" class="btn-secondary">Conoce el proyecto</a>
					</div>
				</div>
			</section>

			<!-- Stats strip -->
			<div class="stats-strip">
				<div class="stat">
					<span class="stat-value">100%</span>
					<span class="stat-label">En español</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-value">IA · Tech</span>
					<span class="stat-label">Categorías clave</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat">
					<span class="stat-value">USA</span>
					<span class="stat-label">Perspectiva latina</span>
				</div>
			</div>

			<!-- Recent posts -->
			{
				recentPosts.length > 0 ? (
					<section class="recent-section">
						<div class="section-header">
							<h2>Artículos recientes</h2>
							<a href="/blog" class="see-all">Ver todos los artículos →</a>
						</div>
						<ul class="cards-grid">
							{recentPosts.map((post, i) => {
								const category = getPostCategory(post.data);
								return (
									<li class="card">
										{post.data.heroImage && (
											<div class="card-img">
												<img
													src={unsplashCard(post.data.heroImage)}
													srcset={unsplashCardSrcset(post.data.heroImage)}
													sizes="(max-width: 600px) 100vw, (max-width: 900px) calc(50vw - 1rem), (min-width: 1100px) 360px, 33vw"
													alt={post.data.title}
													loading={i === 0 ? "eager" : "lazy"}
													fetchpriority={i === 0 ? "high" : "auto"}
													decoding="async"
													width="400"
													height="225"
												/>
											</div>
										)}
										<div class="card-body">
											{category && (
												<a
													class="card-category"
													href={`/categoria/${categoryToSlug(category)}`}
												>
													{category}
												</a>
											)}
											<h2 class="card-title">
												<a href={`/blog/${post.id}/`}>{post.data.title}</a>
											</h2>
											{post.data.description && (
												<p class="card-desc">{post.data.description}</p>
											)}
											<time class="card-date">
												<FormattedDate date={post.data.pubDate} />
											</time>
										</div>
									</li>
								);
							})}
						</ul>
					</section>
				) : (
					<div class="no-posts">
						<p>Próximamente — los primeros artículos están en camino.</p>
					</div>
				)
			}

			<!-- ¿Qué cubrimos? -->
			<section class="seo-section">
				<h2>¿Qué cubrimos en La Tendencia USA?</h2>
				<p>Inteligencia artificial, tecnología, gaming y ciencia — todo en español y sin tecnicismos innecesarios. Seguimos los modelos de IA más recientes como ChatGPT, Claude y Gemini, los gadgets que vale la pena conocer, los lanzamientos de videojuegos que generan conversación, y los descubrimientos científicos que serán la tecnología de mañana. También cubrimos las decisiones estratégicas de Apple, Google, Microsoft y Meta, startups de Silicon Valley, ciberseguridad y todo lo que transforma nuestra vida digital.</p>
				<p>Escribimos para más de 500 millones de hispanohablantes: emprendedores, profesionales, estudiantes y curiosos de México, Colombia, Argentina, España, Chile, Venezuela y cualquier rincón del mundo donde se hable español. La tendencia es global — y este espacio es para todos.</p>
			</section>

			<!-- Quote Section -->
			<section class="quote-section">
				<blockquote class="featured-quote">
					<p>"La tecnología va a cambiar el mundo más rápido de lo que la mayoría de las personas se puede imaginar. La pregunta es: ¿estarás tú entre quienes lo entienden?"</p>
					<cite>— Satya Nadella, CEO de Microsoft</cite>
				</blockquote>
			</section>

			<!-- CTA Banner -->
			<div class="cta-banner">
				<h2>¿Quieres estar al día?</h2>
				<p>Síguenos en redes sociales para no perderte nada sobre tecnología, IA y tendencias digitales en español.</p>
				<a href="/about" class="btn-primary">Conoce más →</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
