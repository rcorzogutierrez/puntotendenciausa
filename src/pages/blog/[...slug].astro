---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => {
		const currentTags = post.data.tags ?? [];
		const currentCategory = post.data.category ?? '';

		const related = posts
			.filter((p) => {
				if (p.id === post.id) return false;
				const sharedTags = (p.data.tags ?? []).filter((t) => currentTags.includes(t));
				const sameCategory = p.data.category === currentCategory;
				return sharedTags.length > 0 || sameCategory;
			})
			.map((p) => ({
				id: p.id,
				title: p.data.title,
				heroImage: p.data.heroImage,
				pubDate: p.data.pubDate,
				category: p.data.category,
				tags: p.data.tags ?? [],
				// Score: shared tags count + same category bonus
				score:
					(p.data.tags ?? []).filter((t) => currentTags.includes(t)).length * 2 +
					(p.data.category === currentCategory ? 1 : 0),
			}))
			.sort((a, b) => b.score - a.score || b.pubDate.valueOf() - a.pubDate.valueOf())
			.slice(0, 3);

		return {
			params: { slug: post.id },
			props: { post, relatedPosts: related },
		};
	});
}

interface RelatedPost {
	id: string;
	title: string;
	heroImage?: string;
	pubDate: Date;
	category?: string;
	tags: string[];
}

interface Props {
	post: CollectionEntry<'blog'>;
	relatedPosts: RelatedPost[];
}

const { post, relatedPosts } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} relatedPosts={relatedPosts}>
	<Content />
</BlogPost>
