---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { categoryToSlug, getPostCategory } from '../../utils/categories';
import { unsplashCard } from '../../utils/images';

export async function getStaticPaths() {
	const allPosts = (await getCollection('blog')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

	// Página 1: 10 artículos (1 destacado + 9 en grid de 3×3)
	// Páginas siguientes: 9 artículos (grid de 3×3 completo)
	const PAGE_SIZE = 9;
	const firstPagePosts = allPosts.slice(0, 10);
	const remaining = allPosts.slice(10);
	const extraPages = Math.ceil(remaining.length / PAGE_SIZE);
	const totalPages = 1 + extraPages;

	const paths = [
		{
			params: { page: undefined },
			props: {
				posts: firstPagePosts,
				currentPage: 1,
				totalPages,
				prevUrl: null,
				nextUrl: extraPages > 0 ? '/blog/2' : null,
			},
		},
	];

	for (let i = 0; i < extraPages; i++) {
		const pageNum = i + 2;
		paths.push({
			params: { page: String(pageNum) },
			props: {
				posts: remaining.slice(i * PAGE_SIZE, (i + 1) * PAGE_SIZE),
				currentPage: pageNum,
				totalPages,
				prevUrl: pageNum === 2 ? '/blog' : `/blog/${pageNum - 1}`,
				nextUrl: pageNum < totalPages ? `/blog/${pageNum + 1}` : null,
			},
		});
	}

	return paths;
}

const { posts, currentPage, totalPages, prevUrl, nextUrl } = Astro.props;
const isFirstPage = currentPage === 1;
const featured = isFirstPage ? posts[0] : null;
const rest = isFirstPage ? posts.slice(1) : posts;
const featuredCategory = featured ? getPostCategory(featured.data) : null;

const pageTitle = isFirstPage
	? `Blog — ${SITE_TITLE}`
	: `Blog — Página ${currentPage} | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={pageTitle} description={SITE_DESCRIPTION} />
		<style>
			.blog-header {
				padding: 2.5em 0 2em;
				border-bottom: 1px solid var(--border);
				margin-bottom: 2.5em;
			}
			.blog-header h1 {
				font-size: 2em;
				margin-bottom: 0.25em;
			}
			.blog-header p {
				color: var(--text-muted);
				margin: 0;
				font-size: 0.95em;
			}

			/* Featured card */
			.featured-card {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 16px;
				overflow: hidden;
				margin-bottom: 3em;
				position: relative;
				transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
			}
			.featured-card:hover {
				border-color: var(--border-hover);
				box-shadow: var(--box-shadow-hover);
				transform: translateY(-2px);
			}
			.featured-card .card-img {
				overflow: hidden;
				aspect-ratio: 16/9;
			}
			.featured-card .card-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 0.4s ease;
			}
			.featured-card:hover .card-img img {
				transform: scale(1.04);
			}
			.featured-card .card-body {
				padding: 2.5em;
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 0.75em;
			}
			.featured-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				font-size: 0.7em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent-light);
				background: var(--accent-glow);
				border: 1px solid rgba(99, 102, 241, 0.3);
				border-radius: 999px;
				padding: 0.35em 0.8em;
				width: fit-content;
			}
			.featured-card .card-title {
				font-size: 1.5em;
				color: var(--text-heading);
				line-height: 1.3;
				margin: 0;
				font-weight: 700;
			}
			.featured-card .card-title a {
				text-decoration: none;
				color: inherit;
			}
			.featured-card .card-title a::after {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 1;
			}
			.featured-card .card-desc {
				color: var(--text-muted);
				font-size: 0.95em;
				line-height: 1.6;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.card-date {
				font-size: 0.8em;
				color: var(--text-muted);
				font-weight: 500;
			}
			.card-category-link {
				position: relative;
				z-index: 2;
				display: inline-flex;
				align-items: center;
				font-size: 0.68em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent-light);
				text-decoration: none;
				width: fit-content;
				transition: color 0.2s ease;
			}
			.card-category-link:hover {
				color: var(--cyan);
			}

			/* Grid cards */
			.cards-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5em;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.card {
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 12px;
				overflow: hidden;
				position: relative;
				transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
			}
			.card:hover {
				border-color: var(--border-hover);
				box-shadow: var(--box-shadow-hover);
				transform: translateY(-3px);
			}
			.card .card-img {
				overflow: hidden;
				aspect-ratio: 16/9;
			}
			.card .card-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 0.4s ease;
			}
			.card:hover .card-img img {
				transform: scale(1.05);
			}
			.card .card-body {
				padding: 1.25em;
				display: flex;
				flex-direction: column;
				gap: 0.5em;
			}
			.card .card-title {
				font-size: 1em;
				color: var(--text-heading);
				line-height: 1.4;
				margin: 0;
				font-weight: 600;
			}
			.card .card-title a {
				text-decoration: none;
				color: inherit;
			}
			.card .card-title a::after {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 1;
			}
			.card .card-desc {
				color: var(--text-muted);
				font-size: 0.85em;
				line-height: 1.55;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* Pagination */
			.pagination {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 1em;
				margin-top: 3.5em;
				padding-bottom: 2em;
			}
			.pagination-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.55em 1.2em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 8px;
				color: var(--text-heading);
				text-decoration: none;
				font-size: 0.9em;
				font-weight: 500;
				transition: border-color 0.2s ease, background 0.2s ease;
			}
			.pagination-btn:hover {
				border-color: var(--border-hover);
				background: var(--accent-glow);
				color: var(--accent-light);
			}
			.pagination-info {
				font-size: 0.85em;
				color: var(--text-muted);
				min-width: 8em;
				text-align: center;
			}

			@media (max-width: 900px) {
				.cards-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}
			@media (max-width: 640px) {
				.featured-card {
					grid-template-columns: 1fr;
				}
				.featured-card .card-body {
					padding: 1.5em;
				}
				.cards-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-header">
				<h1>Blog</h1>
				<p>Tecnología, IA y tendencias digitales explicadas en español.</p>
			</div>

			{
				featured && (
					<div class="featured-card">
						{featured.data.heroImage && (
							<div class="card-img">
								<img src={unsplashCard(featured.data.heroImage, 1200)} alt={featured.data.title} loading="eager" fetchpriority="high" decoding="async" width="1200" height="675" />
							</div>
						)}
						<div class="card-body">
							<span class="featured-badge">&#9733; Destacado</span>
							{featuredCategory && (
								<a
									class="card-category-link"
									href={`/categoria/${categoryToSlug(featuredCategory)}`}
								>
									{featuredCategory}
								</a>
							)}
							<h2 class="card-title">
								<a href={`/blog/${featured.id}/`}>{featured.data.title}</a>
							</h2>
							{featured.data.description && (
								<p class="card-desc">{featured.data.description}</p>
							)}
							<time class="card-date">
								<FormattedDate date={featured.data.pubDate} />
							</time>
						</div>
					</div>
				)
			}

			{
				rest.length > 0 && (
					<ul class="cards-grid">
						{rest.map((post) => {
							const category = getPostCategory(post.data);
							return (
								<li class="card">
									{post.data.heroImage && (
										<div class="card-img">
											<img src={unsplashCard(post.data.heroImage)} alt={post.data.title} loading="lazy" decoding="async" width="800" height="450" />
										</div>
									)}
									<div class="card-body">
										{category && (
											<a
												class="card-category-link"
												href={`/categoria/${categoryToSlug(category)}`}
											>
												{category}
											</a>
										)}
										<h2 class="card-title">
											<a href={`/blog/${post.id}/`}>{post.data.title}</a>
										</h2>
										{post.data.description && (
											<p class="card-desc">{post.data.description}</p>
										)}
										<time class="card-date">
											<FormattedDate date={post.data.pubDate} />
										</time>
									</div>
								</li>
							);
						})}
					</ul>
				)
			}

			{
				totalPages > 1 && (
					<nav class="pagination" aria-label="Paginación del blog">
						{prevUrl ? (
							<a href={prevUrl} class="pagination-btn">&#8592; Anterior</a>
						) : (
							<span class="pagination-btn" style="opacity:0;pointer-events:none">&#8592; Anterior</span>
						)}
						<span class="pagination-info">
							Página {currentPage} de {totalPages}
						</span>
						{nextUrl ? (
							<a href={nextUrl} class="pagination-btn">Siguiente &#8594;</a>
						) : (
							<span class="pagination-btn" style="opacity:0;pointer-events:none">Siguiente &#8594;</span>
						)}
					</nav>
				)
			}
		</main>
		<Footer />
	</body>
</html>
