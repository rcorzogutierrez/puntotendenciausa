---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { categoryToSlug, getPostCategory } from '../utils/categories';

const allPosts = await getCollection('blog');
const categoryCounts = new Map<string, { name: string; count: number }>();

for (const post of allPosts) {
	const category = getPostCategory(post.data);
	if (category) {
		const slug = categoryToSlug(category);
		if (categoryCounts.has(slug)) {
			categoryCounts.get(slug)!.count++;
		} else {
			categoryCounts.set(slug, { name: category, count: 1 });
		}
	}
}

const categories = Array.from(categoryCounts.entries())
	.map(([slug, { name, count }]) => ({ slug, name, count }))
	.sort((a, b) => b.count - a.count);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title={`Categorías — ${SITE_TITLE}`}
			description="Explora todos los temas que cubrimos: tecnología, inteligencia artificial, gadgets y más."
		/>
		<style>
			.page-header {
				padding: 2.5em 0 2em;
				border-bottom: 1px solid var(--border);
				margin-bottom: 2.5em;
			}
			.page-header h1 {
				font-size: 2em;
				margin-bottom: 0.25em;
			}
			.page-header p {
				color: var(--text-muted);
				margin: 0;
				font-size: 0.95em;
			}

			.categories-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25em;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.category-card {
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 14px;
				transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
			}
			.category-card:hover {
				border-color: var(--border-hover);
				box-shadow: var(--box-shadow-hover);
				transform: translateY(-3px);
			}
			.category-card a {
				display: flex;
				flex-direction: column;
				gap: 0.5em;
				padding: 1.75em 2em;
				text-decoration: none;
			}
			.category-name {
				font-size: 1.15em;
				font-weight: 700;
				color: var(--text-heading);
				line-height: 1.3;
			}
			.category-count {
				font-size: 0.82em;
				color: var(--text-muted);
				font-weight: 500;
			}
			.category-arrow {
				font-size: 0.9em;
				color: var(--accent-light);
				margin-top: 0.25em;
				transition: transform 0.2s ease;
			}
			.category-card:hover .category-arrow {
				transform: translateX(4px);
			}

			.empty-state {
				text-align: center;
				padding: 4em 1em;
				color: var(--text-muted);
			}

			@media (max-width: 900px) {
				.categories-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}
			@media (max-width: 540px) {
				.categories-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Categorías</h1>
				<p>
					{categories.length}
					{categories.length === 1 ? 'categoría disponible' : 'categorías disponibles'} ·
					{allPosts.length}
					{allPosts.length === 1 ? 'artículo en total' : 'artículos en total'}
				</p>
			</div>

			{
				categories.length > 0 ? (
					<ul class="categories-grid">
						{categories.map(({ slug, name, count }) => (
							<li class="category-card">
								<a href={`/categoria/${slug}`}>
									<span class="category-name">{name}</span>
									<span class="category-count">
										{count} {count === 1 ? 'artículo' : 'artículos'}
									</span>
									<span class="category-arrow">Ver artículos →</span>
								</a>
							</li>
						))}
					</ul>
				) : (
					<div class="empty-state">
						<p>Aún no hay categorías disponibles.</p>
					</div>
				)
			}
		</main>
		<Footer />
	</body>
</html>
