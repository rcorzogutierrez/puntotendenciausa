---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { categoryToSlug, getPostCategory } from '../utils/categories';
import Comments from '../components/Comments.astro';
import { unsplashCard } from '../utils/images';

interface RelatedPost {
	id: string;
	title: string;
	heroImage?: string;
	pubDate: Date;
	category?: string;
	tags: string[];
}

type Props = CollectionEntry<'blog'>['data'] & { relatedPosts?: RelatedPost[] };

const { title, description, pubDate, updatedDate, heroImage, tags, relatedPosts = [] } = Astro.props;
const category = getPostCategory(Astro.props);
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<!-- Article-specific Open Graph overrides -->
		<meta property="og:type" content="article" />
		<meta property="article:published_time" content={pubDate.toISOString()} />
		{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
		<meta property="og:locale" content="es_US" />
		<!-- Schema Markup: BlogPosting -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"image": heroImage,
			"datePublished": pubDate.toISOString(),
			"dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
			"author": {
				"@type": "Organization",
				"name": "La Tendencia USA",
				"url": "https://latendenciausa.web.app"
			},
			"publisher": {
				"@type": "Organization",
				"name": "La Tendencia USA",
				"url": "https://latendenciausa.web.app"
			}
		})} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: 2em auto 0;
				aspect-ratio: 16 / 9;
				overflow: hidden;
				border-radius: 12px;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center;
			}
			.prose {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em 4em;
				color: var(--text);
			}
			.article-meta {
				display: flex;
				align-items: center;
				gap: 1em;
				margin-bottom: 1.5em;
				flex-wrap: wrap;
			}
			.date {
				font-size: 0.85em;
				color: var(--text-muted);
				font-weight: 500;
			}
			.updated-badge {
				font-size: 0.78em;
				color: var(--accent-light);
				background: var(--accent-glow);
				border: 1px solid rgba(99, 102, 241, 0.25);
				border-radius: 999px;
				padding: 0.2em 0.7em;
				font-style: normal;
			}
			.category-badge {
				font-size: 0.72em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent-light);
				text-decoration: none;
				transition: color 0.2s ease;
			}
			.category-badge:hover {
				color: var(--cyan);
			}
			.prose h1 {
				font-size: 2.25em;
				line-height: 1.2;
				letter-spacing: -0.03em;
				margin-bottom: 1em;
			}
			.prose h2 {
				font-size: 1.5em;
				font-weight: 700;
				line-height: 1.3;
				letter-spacing: -0.02em;
				margin-top: 2em;
				margin-bottom: 0.75em;
				color: var(--text);
			}
			.prose h3 {
				font-size: 1.2em;
				font-weight: 600;
				line-height: 1.4;
				margin-top: 1.5em;
				margin-bottom: 0.5em;
				color: var(--accent-light);
			}
			hr {
				border-top: 1px solid var(--border);
				margin: 2em 0;
			}
			.share-section {
				margin-top: 3em;
				padding-top: 2em;
				border-top: 1px solid var(--border);
			}
			.share-label {
				font-size: 0.8em;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--text-muted);
				margin-bottom: 0.75em;
			}
			.share-buttons {
				display: flex;
				gap: 0.6em;
				flex-wrap: wrap;
			}
			.share-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.5em 1em;
				border-radius: 999px;
				font-size: 0.82em;
				font-weight: 600;
				text-decoration: none;
				border: 1px solid var(--border);
				background: var(--bg-card);
				color: var(--text);
				cursor: pointer;
				transition: border-color 0.2s ease, background 0.2s ease, transform 0.15s ease;
			}
			.share-btn:hover {
				border-color: var(--border-hover);
				transform: translateY(-1px);
			}
			.share-btn.whatsapp:hover { border-color: #25d366; color: #25d366; }
			.share-btn.twitter:hover  { border-color: #1d9bf0; color: #1d9bf0; }
			.share-btn.facebook:hover { border-color: #1877f2; color: #1877f2; }
			.share-btn.copy:hover     { border-color: var(--accent-light); color: var(--accent-light); }
			.copy-feedback {
				display: none;
				font-size: 0.78em;
				color: var(--accent-light);
				align-self: center;
			}

		/* Topics / Tags */
		.topics-section {
			margin-top: 1.5em;
			display: flex;
			align-items: center;
			gap: 0.6em;
			flex-wrap: wrap;
		}
		.topics-label {
			font-size: 0.82em;
			font-weight: 700;
			color: var(--text-muted);
			letter-spacing: 0.04em;
			white-space: nowrap;
		}
		.topic-tag {
			font-size: 0.78em;
			font-weight: 600;
			color: var(--cyan);
			text-decoration: none;
			padding: 0.25em 0.75em;
			border: 1px solid rgba(34, 211, 238, 0.25);
			border-radius: 999px;
			background: rgba(34, 211, 238, 0.06);
			transition: background 0.2s ease, border-color 0.2s ease;
		}
		.topic-tag:hover {
			background: rgba(34, 211, 238, 0.14);
			border-color: rgba(34, 211, 238, 0.5);
		}
		/* Related posts */
		.related-section {
			width: 760px;
			max-width: calc(100% - 2em);
			margin: 0 auto;
			padding: 0 1em 4em;
		}
		.related-section h2 {
			font-size: 1.1em;
			font-weight: 700;
			letter-spacing: 0.06em;
			text-transform: uppercase;
			color: var(--text-muted);
			margin-bottom: 1.25em;
		}
		.related-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 1em;
			list-style: none;
			margin: 0;
			padding: 0;
		}
		.related-card {
			background: var(--bg-card);
			border: 1px solid var(--border);
			border-radius: 10px;
			overflow: hidden;
			position: relative;
			transition: border-color 0.2s ease, transform 0.2s ease;
		}
		.related-card:hover {
			border-color: var(--border-hover);
			transform: translateY(-2px);
		}
		.related-card-img {
			aspect-ratio: 16/9;
			overflow: hidden;
		}
		.related-card-img img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
			transition: transform 0.3s ease;
		}
		.related-card:hover .related-card-img img { transform: scale(1.04); }
		.related-card-body { padding: 0.85em; }
		.related-card-title {
			font-size: 0.88em;
			font-weight: 600;
			line-height: 1.4;
			color: var(--text-heading);
			margin: 0 0 0.35em;
		}
		.related-card-title a {
			text-decoration: none;
			color: inherit;
		}
		.related-card-title a::after {
			content: '';
			position: absolute;
			inset: 0;
			z-index: 1;
		}
		.related-card-title a:hover { color: var(--accent-light); }
		.related-card-date {
			font-size: 0.75em;
			color: var(--text-muted);
		}
		@media (max-width: 700px) {
			.related-grid { grid-template-columns: 1fr; }
		}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article data-pagefind-body>
				<div class="hero-image">
					{heroImage && <img src={heroImage} alt={title} decoding="async" fetchpriority="high" loading="eager" />}
				</div>
				<div class="prose">
					<div class="article-meta">
						<time class="date"><FormattedDate date={pubDate} /></time>
						{
							category && (
								<a
									class="category-badge"
									href={`/categoria/${categoryToSlug(category)}`}
								>
									{category}
								</a>
							)
						}
						{
							updatedDate && (
								<span class="updated-badge">
									Actualizado el <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					<hr />
					<slot />

					{tags && tags.length > 0 && (
						<div class="topics-section">
							<span class="topics-label">Temas:</span>
							{tags.map((tag) => (
								<a class="topic-tag" href={`/tag/${tag}`}>#{tag}</a>
							))}
						</div>
					)}

										<div class="share-section">
						<p class="share-label">Compartir artículo</p>
						<div class="share-buttons">
							<a class="share-btn whatsapp" id="share-whatsapp" target="_blank" rel="noopener noreferrer">
								<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.122 1.528 5.855L.057 23.625a.75.75 0 0 0 .918.918l5.77-1.471A11.943 11.943 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.686-.528-5.204-1.44l-.372-.22-3.862.985.985-3.862-.22-.372A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
								WhatsApp
							</a>
							<a class="share-btn twitter" id="share-twitter" target="_blank" rel="noopener noreferrer">
								<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
								X / Twitter
							</a>
							<a class="share-btn facebook" id="share-facebook" target="_blank" rel="noopener noreferrer">
								<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
								Facebook
							</a>
							<button class="share-btn copy" id="share-copy">
								<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
								Copiar enlace
							</button>
							<span class="copy-feedback" id="copy-feedback">¡Copiado!</span>
						</div>
					</div>
				</div>
			</article>
		{relatedPosts.length > 0 && (
			<div class="related-section">
				<h2>Artículos Relacionados</h2>
				<ul class="related-grid">
					{relatedPosts.map((p) => (
						<li class="related-card">
							{p.heroImage && (
								<div class="related-card-img">
									<img src={unsplashCard(p.heroImage)} alt={p.title} loading="lazy" decoding="async" />
								</div>
							)}
							<div class="related-card-body">
								<h3 class="related-card-title">
									<a href={`/blog/${p.id}/`}>{p.title}</a>
								</h3>
								<time class="related-card-date"><FormattedDate date={p.pubDate} /></time>
							</div>
						</li>
					))}
				</ul>
			</div>
		)}
				<Comments />
		</main>
		<Footer />
	<script>
		const base = window.location.origin + window.location.pathname;
		const title = document.title;

		const utm = (source: string, medium = 'social') =>
			`${base}?utm_source=${source}&utm_medium=${medium}&utm_campaign=share`;

		const wa = document.getElementById('share-whatsapp') as HTMLAnchorElement;
		const tw = document.getElementById('share-twitter') as HTMLAnchorElement;
		const fb = document.getElementById('share-facebook') as HTMLAnchorElement;
		const cp = document.getElementById('share-copy') as HTMLButtonElement;
		const fb_msg = document.getElementById('copy-feedback') as HTMLSpanElement;

		wa.href = `https://wa.me/?text=${encodeURIComponent(title + ' ' + utm('whatsapp'))}`;
		tw.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(utm('twitter'))}`;
		fb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(utm('facebook'))}`;

		cp.addEventListener('click', () => {
			navigator.clipboard.writeText(utm('clipboard', 'referral')).then(() => {
				fb_msg.style.display = 'inline';
				setTimeout(() => { fb_msg.style.display = 'none'; }, 2000);
			});
		});
	</script>
	</body>
</html>
