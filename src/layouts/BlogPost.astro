---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { categoryToSlug, getPostCategory } from '../utils/categories';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const category = getPostCategory(Astro.props);
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<!-- Article-specific Open Graph overrides -->
		<meta property="og:type" content="article" />
		<meta property="article:published_time" content={pubDate.toISOString()} />
		{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
		<meta property="og:locale" content="es_US" />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 100%;
				max-height: 500px;
				overflow: hidden;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				margin: 0;
			}
			.prose {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em 4em;
				color: var(--text);
			}
			.article-meta {
				display: flex;
				align-items: center;
				gap: 1em;
				margin-bottom: 1.5em;
				flex-wrap: wrap;
			}
			.date {
				font-size: 0.85em;
				color: var(--text-muted);
				font-weight: 500;
			}
			.updated-badge {
				font-size: 0.78em;
				color: var(--accent-light);
				background: var(--accent-glow);
				border: 1px solid rgba(99, 102, 241, 0.25);
				border-radius: 999px;
				padding: 0.2em 0.7em;
				font-style: normal;
			}
			.category-badge {
				font-size: 0.72em;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent-light);
				text-decoration: none;
				transition: color 0.2s ease;
			}
			.category-badge:hover {
				color: var(--cyan);
			}
			.prose h1 {
				font-size: 2.25em;
				line-height: 1.2;
				letter-spacing: -0.03em;
				margin-bottom: 1em;
			}
			hr {
				border-top: 1px solid var(--border);
				margin: 2em 0;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img src={heroImage} alt="" decoding="async" />}
				</div>
				<div class="prose">
					<div class="article-meta">
						<time class="date"><FormattedDate date={pubDate} /></time>
						{
							category && (
								<a
									class="category-badge"
									href={`/categoria/${categoryToSlug(category)}`}
								>
									{category}
								</a>
							)
						}
						{
							updatedDate && (
								<span class="updated-badge">
									Actualizado el <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					<hr />
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
