---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string | ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage } = Astro.props;
const imageSrc = typeof image === 'string' ? image : image.src;

// Title: formato "[Título] | La Tendencia USA", máximo 60 caracteres
// Si el título ya incluye el nombre del sitio (homepage, categorías), se usa tal cual
const SUFFIX = ` | ${SITE_TITLE}`;
const needsSuffix = !title.includes(SITE_TITLE);
let pageTitle: string;
if (needsSuffix) {
	const maxTitleChars = 60 - SUFFIX.length - 3;
	const titlePart = title.length + SUFFIX.length <= 60
		? title
		: title.slice(0, maxTitleChars) + '...';
	pageTitle = `${titlePart}${SUFFIX}`;
} else {
	pageTitle = title.length <= 60 ? title : title.slice(0, 57) + '...';
}

// Description: máximo 160 caracteres
const metaDescription = description.length <= 160
	? description
	: description.slice(0, 157) + '...';
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<!-- Google Fonts: Inter (async, no render-blocking) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" /></noscript>
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={metaDescription} />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
<meta name="author" content="La Tendencia USA" />
<meta name="language" content="Spanish" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={new URL(imageSrc, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={metaDescription} />
<meta property="twitter:image" content={new URL(imageSrc, Astro.url)} />

<!-- Schema Markup: WebSite -->
<script type="application/ld+json" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "La Tendencia USA",
	"url": "https://latendenciausa.web.app",
	"description": "Blog de tecnología en español para latinos en USA"
})} />

<!-- Google Analytics 4 — ejecutado en Web Worker via Partytown (off main thread) -->
<script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-QK0Z3S712M"></script>
<script type="text/partytown">
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-QK0Z3S712M');
</script>
