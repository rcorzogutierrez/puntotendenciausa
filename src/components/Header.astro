---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo" aria-label="La Tendencia USA — Inicio">
			<span class="logo-icon" aria-hidden="true">T</span>
			<span class="logo-main">La Tendencia</span><span class="logo-accent">USA</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">Nosotros</HeaderLink>
		</div>
		<div class="nav-actions">
			<a href="/blog" class="nav-cta">Leer Blog →</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 1.5em;
		background: rgba(15, 23, 42, 0.92);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 64px;
		gap: 2em;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.45em;
		text-decoration: none;
		font-size: 1.15em;
		font-weight: 800;
		letter-spacing: -0.03em;
		white-space: nowrap;
		flex-shrink: 0;
	}
	.logo-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		background: var(--accent);
		border-radius: 7px;
		color: #fff;
		font-size: 0.78em;
		font-weight: 900;
		letter-spacing: 0;
		flex-shrink: 0;
		transition: background 0.2s ease;
	}
	.logo:hover .logo-icon {
		background: var(--accent-light);
	}
	.logo-main {
		color: var(--text-heading);
	}
	.logo-accent {
		color: var(--accent-light);
	}
	.logo:hover .logo-main {
		color: #fff;
	}
	.logo:hover .logo-accent {
		color: var(--cyan);
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		flex-shrink: 0;
	}

	.nav-cta {
		display: inline-flex;
		align-items: center;
		padding: 0.45em 1.1em;
		background: var(--accent);
		color: #fff !important;
		font-size: 0.85em;
		font-weight: 600;
		border-radius: 999px;
		text-decoration: none;
		letter-spacing: 0;
		transition: background 0.2s ease, transform 0.15s ease;
	}
	.nav-cta:hover {
		background: var(--accent-light);
		transform: translateY(-1px);
		color: #fff !important;
	}

	@media (max-width: 640px) {
		.nav-actions {
			display: none;
		}
		nav {
			gap: 1em;
		}
	}
</style>
