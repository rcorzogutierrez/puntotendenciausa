---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<a href="/" class="footer-logo">
				<span class="logo-main">La Tendencia</span><span class="logo-accent">USA</span>
			</a>
			<p class="footer-tagline">Tecnología, IA y tendencias digitales explicadas en español.</p>
		</div>

		<nav class="footer-nav" aria-label="Footer navigation">
			<a href="/">Inicio</a>
			<a href="/blog">Blog</a>
			<a href="/about">Nosotros</a>
		</nav>

		<div class="footer-social">
			<a href="https://facebook.com/latendenciausa" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
					<path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>
				</svg>
			</a>
			<a href="https://x.com/latendenciausa" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
					<path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
				</svg>
			</a>
		</div>
	</div>

	<div class="footer-bottom">
		<span>&copy; {today.getFullYear()} La Tendencia USA. Todos los derechos reservados.</span>
	</div>
</footer>

<style>
	footer {
		background: var(--bg-surface);
		border-top: 1px solid var(--border);
		margin-top: 4em;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3em 1.5em 2em;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2em;
		flex-wrap: wrap;
	}

	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}

	.footer-logo {
		display: inline-flex;
		align-items: baseline;
		gap: 0.2em;
		font-size: 1.1em;
		font-weight: 800;
		letter-spacing: -0.03em;
		text-decoration: none;
	}
	.logo-main {
		color: var(--text-heading);
	}
	.logo-accent {
		color: var(--accent-light);
	}
	.footer-logo:hover .logo-accent {
		color: var(--cyan);
	}

	.footer-tagline {
		margin: 0;
		font-size: 0.85em;
		color: var(--text-muted);
		max-width: 280px;
		line-height: 1.5;
	}

	.footer-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}
	.footer-nav a {
		font-size: 0.9em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.footer-nav a:hover {
		color: var(--accent-light);
	}

	.footer-social {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	.footer-social a {
		display: flex;
		align-items: center;
		color: var(--text-muted);
		padding: 0.5em;
		border-radius: 8px;
		border: 1px solid var(--border);
		transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}
	.footer-social a:hover {
		color: var(--accent-light);
		border-color: var(--border-hover);
		background: var(--bg-card);
	}

	.footer-bottom {
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.25em 1.5em;
		border-top: 1px solid var(--border);
		font-size: 0.8em;
		color: var(--text-muted);
	}

	@media (max-width: 600px) {
		.footer-inner {
			flex-direction: column;
			gap: 2em;
		}
		.footer-social {
			flex-direction: row;
		}
	}
</style>
