---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<a href="/" class="footer-logo">
				<span class="logo-main">La Tendencia</span><span class="logo-accent">USA</span>
			</a>
			<p class="footer-tagline">Tecnología, IA y tendencias digitales explicadas en español.</p>
		</div>

		<nav class="footer-nav" aria-label="Footer navigation">
			<a href="/">Inicio</a>
			<a href="/blog">Blog</a>
			<a href="/about">Nosotros</a>
		</nav>

		<div class="footer-social">
			<a href="https://facebook.com/latendenciausa" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
					<path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>
				</svg>
			</a>
			<a href="https://instagram.com/latendenciausa" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
					<path fill="currentColor" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path>
				</svg>
			</a>
		</div>
	</div>

	<div class="footer-bottom">
		<span>&copy; {today.getFullYear()} La Tendencia USA. Todos los derechos reservados.</span>
	</div>
</footer>

<style>
	footer {
		background: var(--bg-surface);
		border-top: 1px solid var(--border);
		margin-top: 4em;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3em 1.5em 2em;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2em;
		flex-wrap: wrap;
	}

	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}

	.footer-logo {
		display: inline-flex;
		align-items: baseline;
		gap: 0.2em;
		font-size: 1.1em;
		font-weight: 800;
		letter-spacing: -0.03em;
		text-decoration: none;
	}
	.logo-main {
		color: var(--text-heading);
	}
	.logo-accent {
		color: var(--accent-light);
	}
	.footer-logo:hover .logo-accent {
		color: var(--cyan);
	}

	.footer-tagline {
		margin: 0;
		font-size: 0.85em;
		color: var(--text-muted);
		max-width: 280px;
		line-height: 1.5;
	}

	.footer-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}
	.footer-nav a {
		font-size: 0.9em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.footer-nav a:hover {
		color: var(--accent-light);
	}

	.footer-social {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	.footer-social a {
		display: flex;
		align-items: center;
		color: var(--text-muted);
		padding: 0.5em;
		border-radius: 8px;
		border: 1px solid var(--border);
		transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}
	.footer-social a:hover {
		color: var(--accent-light);
		border-color: var(--border-hover);
		background: var(--bg-card);
	}

	.footer-bottom {
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.25em 1.5em;
		border-top: 1px solid var(--border);
		font-size: 0.8em;
		color: var(--text-muted);
	}

	@media (max-width: 600px) {
		.footer-inner {
			flex-direction: column;
			gap: 2em;
		}
		.footer-social {
			flex-direction: row;
		}
	}
</style>
